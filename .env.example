DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
TZ=America/Mexico_City
# USE_SQLITE=true permite ejecutar pruebas o desarrollo sin PostgreSQL.
USE_SQLITE=false

POSTGRES_DB=goey_smar
POSTGRES_USER=goey_smar
POSTGRES_PASSWORD=replace-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
MONITOR_INTERVAL_SECONDS=120

AMAZON_SAVED_ITEMS_URL=https://www.amazon.com.mx/gp/cart/view.html
AMAZON_BASE_URL=https://www.amazon.com.mx
AMAZON_ASSOCIATE_TAG=
AMAZON_PROFILE_DIR=.amazon-profile
AMAZON_HEADLESS=true
AMAZON_TIMEOUT_MS=45000

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ERROR_CHAT_ID=

# Alertas por email cuando falla la ejecucion del scraper.
# Para Gmail use una contrasena de aplicacion, no la contrasena normal.
# Si MONITOR_FAILURE_EMAIL_RECIPIENTS queda vacio, se usara TELEGRAM_ERROR_CHAT_ID.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=tu-contrasena-de-aplicacion
DEFAULT_FROM_EMAIL=tu-correo@gmail.com
MONITOR_FAILURE_EMAIL_RECIPIENTS=destino@example.com
MONITOR_FAILURE_EMAIL_SUBJECT_PREFIX=[Goey SMAR]
